#!/usr/bin/env python3
"""cluster-manage — entrypoint shim. Requires the scratch_keeper package
to be importable. The simplest way: symlink this file into a directory on
$PATH after cloning ~/scratch-keeper:

    ln -s ~/scratch-keeper/bin/cluster-manage ~/.local/bin/cluster-manage
"""
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
if str(REPO) not in sys.path:
    sys.path.insert(0, str(REPO))

from scratch_keeper.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
