{
  "name": "kcw-agent",
  "path": "kcw-agent",
  "category": "keeper",
  "backup_globs": [
    "**/*.in", "**/*.cif", "**/*.UPF", "**/*.upf",
    "**/*.xml", "**/*.out", "**/*.json",
    "**/parsed/**", "**/plots/**",
    "**/*.png", "**/*.pdf", "**/*.ipynb",
    "**/run.sh", "**/*.slurm"
  ],
  "exclude_globs": [
    "**/out/**", "**/*.wfc*", "**/*.save/**",
    "**/tmp/**", "**/__pycache__/**", "**/.git/**"
  ],
  "touch_globs": ["**/*"],
  "touch_exclude_globs": ["**/*.wfc*", "**/out/**"],
  "notes": "KCW agent project. Active."
}
