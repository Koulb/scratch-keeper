{
  "name": "electron_phonon",
  "path": "electron_phonon",
  "category": "keeper",
  "backup_globs": [
    "**/*.in", "**/*.cif", "**/*.UPF", "**/*.upf",
    "**/*.xml", "**/*.out",
    "**/summary.json", "**/parsed/**", "**/plots/**",
    "**/*.png", "**/*.pdf", "**/*.ipynb",
    "**/run.sh", "**/*.slurm",
    "**/*.epb", "**/*.epmatwp", "**/*.fmt"
  ],
  "exclude_globs": [
    "**/out/**", "**/*.wfc*", "**/*.save/**",
    "**/tmp/**", "**/__pycache__/**", "**/.git/**"
